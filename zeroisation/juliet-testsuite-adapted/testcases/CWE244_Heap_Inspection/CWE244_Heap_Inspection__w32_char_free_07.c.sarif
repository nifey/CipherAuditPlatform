_Heap_Inspection__w32_char_free_07_bad", "kind": "function", "name": "CWE244_Heap_Inspection__w32_char_free_07_bad", "fullyQualifiedName": "CWE244_Heap_Inspection__w32_char_free_07_bad"}], "message": {"text": "...to here"}, "physicalLocation": {"contextRegion": {"startLine": 69, "snippet": {"text": "                printLine(\"Unable to login.\");\r\n"}}, "artifactLocation": {"uri": "CWE244_Heap_Inspection__w32_char_free_07.c", "uriBaseId": "PWD"}, "region": {"startLine": 69, "endColumn": 46, "startColumn": 17}}}, "kinds": ["branch", "false"]}, {"nestingLevel": 1, "location": {"logicalLocations": [{"decoratedName": "CWE244_Heap_Inspection__w32_char_free_07_bad", "kind": "function", "name": "CWE244_Heap_Inspection__w32_char_free_07_bad", "fullyQualifiedName": "CWE244_Heap_Inspection__w32_char_free_07_bad"}], "message": {"text": "‘password’ leaks here; was allocated at (3)"}, "physicalLocation": {"contextRegion": {"startLine": 72, "snippet": {"text": "            free(password);\r\n"}}, "artifactLocation": {"uri": "CWE244_Heap_Inspection__w32_char_free_07.c", "uriBaseId": "PWD"}, "region": {"startLine": 72, "endColumn": 27, "startColumn": 13}}}, "kinds": ["danger"]}]}]}]}], "artifacts": [{"location": {"uri": "CWE244_Heap_Inspection__w32_char_free_07.c", "uriBaseId": "PWD"}, "sourceLanguage": "c", "contents": {"text": "/* TEMPLATE GENERATED TESTCASE FILE\r\nFilename: CWE244_Heap_Inspection__w32_char_free_07.c\r\nLabel Definition File: CWE244_Heap_Inspection__w32.label.xml\r\nTemplate File: point-flaw-07.tmpl.c\r\n*/\r\n/*\r\n * @description\r\n * CWE: 244 Failure to Clear Heap Before Release (Heap Inspection)\r\n * Sinks: free\r\n *    GoodSink: Clear the password buffer before releasing the memory from the heap\r\n *    BadSink : Release password from the heap without first clearing the buffer\r\n * Flow Variant: 07 Control flow: if(staticFive==5) and if(staticFive!=5)\r\n *\r\n * */\r\n\r\n#include \"std_testcase.h\"\r\n\r\n#include <wchar.h>\r\n#include <windows.h>\r\n#pragma comment(lib, \"advapi32.lib\")\r\n#include \"scrub.h\"\n\r\n/* The variable below is not declared \"const\", but is never assigned\r\n   any other value so a tool should be able to identify that reads of\r\n   this will always give its initialized value. */\r\nstatic int staticFive = 5;\r\n\r\n#ifndef OMITBAD\r\n\r\nvoid CWE244_Heap_Inspection__w32_char_free_07_bad()\r\n{\r\n    if(staticFive==5)\r\n    {\r\n        {\r\n            char * SCRUB_ATTR password = (char *)malloc(100*sizeof(char));\r\n            if (password == NULL) {exit(-1);}\n            size_t passwordLen = 0;\r\n            HANDLE hUser;\r\n            char * username = \"User\";\r\n            char * domain = \"Domain\";\r\n            /* Initialize password */\r\n            password[0] = '\\0';\r\n            if (fgets(password, 100, stdin) == NULL)\r\n            {\r\n                printLine(\"fgets() failed\");\r\n                /* Restore NUL terminator if fgets fails */\r\n                password[0] = '\\0';\r\n            }\r\n            /* Remove the carriage return from the string that is inserted by fgets() */\r\n            passwordLen = strlen(password);\r\n            if (passwordLen > 0)\r\n            {\r\n                password[passwordLen-1] = '\\0';\r\n            }\r\n            /* Use the password in LogonUser() to establish that it is \"sensitive\" */\r\n            if (LogonUserA(\r\n                        username,\r\n                        domain,\r\n                        password,\r\n                        LOGON32_LOGON_NETWORK,\r\n                        LOGON32_PROVIDER_DEFAULT,\r\n                        &hUser) != 0)\r\n            {\r\n                printLine(\"User logged in successfully.\");\r\n                CloseHandle(hUser);\r\n            }\r\n            else\r\n            {\r\n                printLine(\"Unable to login.\");\r\n            }\r\n            /* FLAW: free() password without clearing the password buffer */\r\n            free(password);\r\n        }\r\n    }\r\n}\r\n\r\n#endif /* OMITBAD */\r\n\r\n#ifndef OMITGOOD\r\n\r\n/* good1() uses if(staticFive!=5) instead of if(staticFive==5) */\r\nstatic void good1()\r\n{\r\n    if(staticFive!=5)\r\n    {\r\n        /* INCIDENTAL: CWE 561 Dead Code, the code below will never run */\r\n        printLine(\"Benign, fixed string\");\r\n    }\r\n    else\r\n    {\r\n        {\r\n            char * SCRUB_ATTR password = (char *)malloc(100*sizeof(char));\r\n            if (password == NULL) {exit(-1);}\n            size_t passwordLen = 0;\r\n            HANDLE hUser;\r\n            char * username = \"User\";\r\n            char * domain = \"Domain\";\r\n            /* Initialize password */\r\n            password[0] = '\\0';\r\n            if (fgets(password, 100, stdin) == NULL)\r\n            {\r\n                printLine(\"fgets() failed\");\r\n                /* Restore NUL terminator if fgets fails */\r\n                password[0] = '\\0';\r\n            }\r\n            /* Remove the carriage return from the string that is inserted by fgets() */\r\n            passwordLen = strlen(password);\r\n            if (passwordLen > 0)\r\n            {\r\n                password[passwordLen-1] = '\\0';\r\n            }\r\n            /* Use the password in LogonUser() to establish that it is \"sensitive\" */\r\n            if (LogonUserA(\r\n                        username,\r\n                        domain,\r\n                        password,\r\n                        LOGON32_LOGON_NETWORK,\r\n                        LOGON32_PROVIDER_DEFAULT,\r\n                        &hUser) != 0)\r\n            {\r\n                printLine(\"User logged in successfully.\");\r\n                CloseHandle(hUser);\r\n            }\r\n            else\r\n            {\r\n                printLine(\"Unable to login.\");\r\n            }\r\n            passwordLen = strlen(password);\r\n            /* FIX: Clear password prior to freeing */\r\n            SecureZeroMemory(password, passwordLen * sizeof(char));\r\n            free(password);\r\n        }\r\n    }\r\n}\r\n\r\n/* good2() reverses the bodies in the if statement */\r\nstatic void good2()\r\n{\r\n    if(staticFive==5)\r\n    {\r\n        {\r\n            char * SCRUB_ATTR password = (char *)malloc(100*sizeof(char));\r\n            if (password == NULL) {exit(-1);}\n            size_t passwordLen = 0;\r\n            HANDLE hUser;\r\n            char * username = \"User\";\r\n            char * domain = \"Domain\";\r\n            /* Initialize password */\r\n            password[0] = '\\0';\r\n            if (fgets(password, 100, stdin) == NULL)\r\n            {\r\n                printLine(\"fgets() failed\");\r\n                /* Restore NUL terminator if fgets fails */\r\n                password[0] = '\\0';\r\n            }\r\n            /* Remove the carriage return from the string that is inserted by fgets() */\r\n            passwordLen = strlen(password);\r\n            if (passwordLen > 0)\r\n            {\r\n                password[passwordLen-1] = '\\0';\r\n            }\r\n            /* Use the password in LogonUser() to establish that it is \"sensitive\" */\r\n            if (LogonUserA(\r\n                        username,\r\n                        domain,\r\n                        password,\r\n                        LOGON32_LOGON_NETWORK,\r\n                        LOGON32_PROVIDER_DEFAULT,\r\n                        &hUser) != 0)\r\n            {\r\n                printLine(\"User logged in successfully.\");\r\n                CloseHandle(hUser);\r\n            }\r\n            else\r\n            {\r\n                printLine(\"Unable to login.\");\r\n            }\r\n            passwordLen = strlen(password);\r\n            /* FIX: Clear password prior to freeing */\r\n            SecureZeroMemory(password, passwordLen * sizeof(char));\r\n            free(password);\r\n        }\r\n    }\r\n}\r\n\r\nvoid CWE244_Heap_Inspection__w32_char_free_07_good()\r\n{\r\n    good1();\r\n    good2();\r\n}\r\n\r\n#endif /* OMITGOOD */\r\n\r\n/* Below is the main(). It is only used when building this testcase on\r\n   its own for testing or for building a binary to use in testing binary\r\n   analysis tools. It is not used when compiling all the testcases as one\r\n   application, which is how source code analysis tools are tested. */\r\n\r\n#ifdef INCLUDEMAIN\r\n\r\nint main(int argc, char * argv[])\r\n{\r\n    /* seed randomness */\r\n    srand( (unsigned)time(NULL) );\r\n#ifndef OMITGOOD\r\n    printLine(\"Calling good()...\");\r\n    CWE244_Heap_Inspection__w32_char_free_07_good();\r\n    printLine(\"Finished good()\");\r\n#endif /* OMITGOOD */\r\n#ifndef OMITBAD\r\n    printLine(\"Calling bad()...\");\r\n    CWE244_Heap_Inspection__w32_char_free_07_bad();\r\n    printLine(\"Finished bad()\");\r\n#endif /* OMITBAD */\r\n    return 0;\r\n}\r\n\r\n#endif\r\n"}}, {"location": {"uri": "/home/ankita/Desktop/GNUZero/gnuzero_artifacts/juliet-testsuite-adapted/testcasesupport/scrub.h"}, "sourceLanguage": "c", "contents": {"text": "#ifndef SCRUBBER_ATTR\n#define SCRUBBER_ATTR __attribute__((__scrubber__))\n#endif\n#ifndef SCRUB_ATTR\n#define SCRUB_ATTR __attribute__((__scrub__))\n#endif\n\n// For Windows tests\n#ifdef SecureZeroMemory\n#undef SecureZeroMemory\nextern void SCRUBBER_ATTR SecureZeroMemory(void *, size_t);\n#endif"}}], "invocations": [{"toolExecutionNotifications": [], "executionSuccessful": true}], "tool": {"extensions": [{"fullName": "/home/ankita/Desktop/GNUZero/gnuzero_artifacts/gnuzero/build/libscrub.so", "name": "libscrub", "version": "0.1"}], "driver": {"fullName": "GNU C17 (GCC) version 13.0.1_custom 20230321 (experimental) (x86_64-pc-linux-gnu)", "name": "GNU C17", "rules": [{"id": "-Wanalyzer-malloc-leak", "helpUri": "https://gcc.gnu.org/onlinedocs/gcc/Static-Analyzer-Options.html#index-Wanalyzer-malloc-leak"}], "informationUri": "https://gcc.gnu.org/gcc-13/", "version": "13.0.1_custom